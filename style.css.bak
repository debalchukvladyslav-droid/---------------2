/* =========================================
   TRADING JOURNAL PRO - MODERN UI/UX
   (Combined with Original Foundation)
   ========================================= */

/* БАЗОВІ ЗМІННІ (Темна тема - Modern) */
:root {
    /* === DYNAMIC THEME VARIABLES (neutral dark fallback) === */
    --bg-color:       #0b0f19;   /* Primary page background */
    --panel-color:    #111625;   /* Surface / card background */
    --primary-color:  #3b82f6;   /* Brand accent / interactive */
    --text-primary:   #f3f4f6;   /* High-contrast body text */
    --text-secondary: #9ca3af;   /* Muted / supporting text */

    /* === EXISTING TOKENS (mapped to dynamic vars) === */
    --bg-main:   var(--bg-color);
    --bg-panel:  var(--panel-color);
    --bg-hover:  #1b2236;
    
    --text-main:  var(--text-primary);
    --text-muted: var(--text-secondary);
    
    --accent:       var(--primary-color);
    --accent-hover: #60a5fa;  
    --profit: #10b981;
    --loss:   #ef4444;
    --border: rgba(156, 163, 175, 0.15);
    
    --gold: #f59e0b;          
    --ai-bg: color-mix(in srgb, var(--accent) 5%, transparent);
    --ai-border: var(--accent);
    
    --font-main: 'Inter', sans-serif;

    /* === GLASSMORPHISM — only active when body.glass-enabled === */

/* Without the class: solid opaque surfaces (default fallback) */
.sidebar,
.panel,
.stat-card,
.main-tabs,
.team-toggle-btn,
.sidebar-toggle-btn,
.stats-bar-trigger,
.stats-bar-dropdown,
.more-tabs-dropdown,
.tag-suggestions,
#tooltip,
.modal-content.sos-theme,
.auth-card,
.mobile-tabs-wrapper,
.mobile-bottom-nav {
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    background: var(--bg-panel);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
}

/* With the class: full frosted-glass treatment */
body.glass-enabled .sidebar,
body.glass-enabled .panel,
body.glass-enabled .stat-card,
body.glass-enabled .main-tabs,
body.glass-enabled .team-toggle-btn,
body.glass-enabled .sidebar-toggle-btn,
body.glass-enabled .stats-bar-trigger,
body.glass-enabled .stats-bar-dropdown,
body.glass-enabled .more-tabs-dropdown,
body.glass-enabled .tag-suggestions,
body.glass-enabled #tooltip,
body.glass-enabled .modal-content.sos-theme,
body.glass-enabled .auth-card,
body.glass-enabled .mobile-tabs-wrapper,
body.glass-enabled .mobile-bottom-nav {
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: var(--glass-border);
    box-shadow: var(--glass-shadow);
}

/* Toggle switch widget */
.toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.toggle-switch {
    position: relative;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
}
.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
}
.toggle-track {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: var(--border);
    cursor: pointer;
    transition: background 0.2s ease;
}
.toggle-track::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s ease;
}
.toggle-switch input:checked + .toggle-track {
    background: var(--accent);
}
.toggle-switch input:checked + .toggle-track::after {
    transform: translateX(20px);
}
    /* Blur + saturation for the frosted-glass effect */
    --glass-blur:       blur(16px) saturate(120%);
    /* Subtle inner highlight that mimics a physical glass edge */
    --glass-border:     1px solid rgba(255, 255, 255, 0.08);
    /* Soft drop-shadow to lift glass elements off the wallpaper */
    --glass-shadow:     0 8px 32px 0 rgba(0, 0, 0, 0.3);

    /* Нові змінні для тіней та радіусів */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.5), 0 2px 4px -1px rgba(0, 0, 0, 0.3);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.6), 0 4px 6px -2px rgba(0, 0, 0, 0.4);
    --shadow-glow: 0 0 30px color-mix(in srgb, var(--accent) 15%, transparent);
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 18px;
    --radius-xl: 24px;
    --transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, opacity 0.2s ease, box-shadow 0.2s ease;
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
}

/* СВІТЛА ТЕМА */
[data-theme="light"] {
    --bg-color:       #f1f5f9;
    --panel-color:    #ffffff;
    --primary-color:  #2563eb;
    --text-primary:   #0f172a;
    --text-secondary: #64748b;
    --bg-hover: #e2e8f0;
    --accent-hover: #1d4ed8;
    --profit: #059669; --loss: #dc2626; --border: #cbd5e1;
    --gold: #d97706; --ai-bg: #e0e7ff; --ai-border: #6366f1;
    /* Light surfaces need higher opacity to keep text readable */
    --glass-opacity:  80%;
    --glass-border:   1px solid rgba(0, 0, 0, 0.06);
    --glass-shadow:   0 8px 32px 0 rgba(0, 0, 0, 0.12);
}

/* МАТРИЦЯ (ТЕРМІНАЛ) */
[data-theme="matrix"] {
    --bg-color:       #000000;
    --panel-color:    #0a0a0a;
    --primary-color:  #00dd00;
    --text-primary:   #00ff00;
    --text-secondary: #008800;
    --bg-hover: #111111;
    --accent-hover: #00ff00;
    --profit: #00ff00; --loss: #ff0000; --border: #003300;
    --gold: #aaaa00; --ai-bg: #001100; --ai-border: #00ff00;
    /* Matrix: near-opaque so the green-on-black aesthetic is preserved */
    --glass-opacity:  90%;
    --glass-border:   1px solid rgba(0, 255, 0, 0.12);
}

/* ДРАКУЛА */
[data-theme="dracula"] {
    --bg-color:       #282a36;
    --panel-color:    #44475a;
    --primary-color:  #bd93f9;
    --text-primary:   #f8f8f2;
    --text-secondary: #8be9fd;
    --bg-hover: #6272a4;
    --accent-hover: #ff79c6;
    --profit: #50fa7b; --loss: #ff5555; --border: #6272a4;
    --gold: #f1fa8c; --ai-bg: #282a36; --ai-border: #bd93f9;
}

/* Шрифти */
[data-font="inter"] { --font-main: 'Inter', sans-serif; }
[data-font="roboto"] { --font-main: 'Roboto', sans-serif; }
[data-font="montserrat"] { --font-main: 'Montserrat', sans-serif; }
[data-font="playfair"] { --font-main: 'Playfair Display', serif; }
[data-font="mono"] { --font-main: 'Courier New', Courier, monospace; }

input[type="date"] { color-scheme: dark; }
[data-theme="light"] input[type="date"] { color-scheme: light; }

.discipline-slider { width:100%; height:6px; border-radius:3px; outline:none; cursor:pointer; transition: accent-color 0.3s ease; }
.discipline-slider::-webkit-slider-thumb { width:20px; height:20px; border-radius:50%; cursor:pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; }
.discipline-slider::-webkit-slider-thumb:hover { transform: scale(1.3); box-shadow: 0 0 8px currentColor; }
.discipline-slider:active::-webkit-slider-thumb { transform: scale(1.5); box-shadow: 0 0 14px currentColor; }
.discipline-slider::-moz-range-thumb { width:20px; height:20px; border-radius:50%; cursor:pointer; border:none; transition: transform 0.2s ease; }
.discipline-slider::-moz-range-thumb:hover { transform: scale(1.3); }
 background:var(--bg-main); border:1px solid var(--border); border-radius:var(--radius-md); padding:16px; margin-bottom:12px; transition:var(--transition); }
.playbook-item:hover { border-color:var(--accent); }
.playbook-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.playbook-name { font-weight:700; font-size:1.05rem; color:var(--accent); }
.playbook-desc { color:var(--text-muted); font-size:0.9rem; line-height:1.6; white-space:pre-wrap; }

/* Скроллбари */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg-main); border-radius: 4px; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* === ГЛОБАЛЬНІ СТИЛІ === */
* { box-sizing: border-box; margin: 0; padding: 0; outline: none; }
button, a, input, select, textarea { touch-action: manipulation; }
body { 
    font-family: var(--font-main); 
    background: var(--bg-main); 
    color: var(--text-main); 
    margin: 0; 
    padding: var(--spacing-lg); 
    display: flex; 
    gap: var(--spacing-lg); 
    height: 100vh; 
    box-sizing: border-box; 
    overflow: hidden; 
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    letter-spacing: -0.01em;
    will-change: auto;
    /* Ensure background-image set by JS covers the full viewport */
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
}
h2, h3 { margin: 0 0 16px 0; font-weight: 600; letter-spacing: -0.5px; }

/* === ЛІВА ПАНЕЛЬ (SIDEBAR) === */
.sidebar { 
    width: 380px; 
    min-width: 380px; 
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    padding: var(--spacing-lg); 
    border-radius: var(--radius-xl); 
    border: var(--glass-border); 
    display: flex; 
    flex-direction: column; 
    box-shadow: var(--glass-shadow); 
    overflow-y: auto; 
    overflow-x: hidden; 
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), min-width 0.3s, padding 0.3s, opacity 0.2s; 
}
/* Клас для прихованої панелі */
.sidebar.collapsed {
    width: 0 !important;
    min-width: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    border: none !important;
    opacity: 0;
    margin: 0 !important;
}

.header-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.date-display { 
    font-size: 1.25rem; 
    font-weight: 700; 
    color: var(--text-main); /* Змінили з --accent на --text-main */
    flex-grow: 1; 
    text-align: center; 
    cursor: pointer;
}

.date-nav-btn { background: var(--bg-main); border: 1px solid var(--border); color: var(--text-muted); width: 32px; height: 32px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-weight: bold; transition: var(--transition); flex-shrink: 0;}
.date-nav-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }

/* Внутрішні вкладки (Профіт, Думка, Помилки) */
.tabs { display: flex; background: var(--bg-main); padding: 4px; border-radius: var(--radius-sm); margin-bottom: 20px; flex-shrink: 0; }
.tab-btn { flex: 1; padding: 8px 0; text-align: center; background: transparent; color: var(--text-muted); border: none; border-radius: 6px; cursor: pointer; font-weight: 600; transition: var(--transition); font-size: 0.9rem; font-family: inherit;}
.tab-btn.active { background: var(--bg-panel); color: var(--text-main); box-shadow: var(--shadow-sm); }
.tab-content { display: none; flex-grow: 1; overflow-y: auto; overflow-x: hidden; padding-right: 5px;}
.tab-content.active { display: block; }

/* === ФОРМИ ТА ЕЛЕМЕНТИ === */
.form-group { margin-bottom: 15px; width: 100%; box-sizing: border-box;}
label { display: block; margin-bottom: 6px; font-size: 0.85rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;}

input[type="text"], input[type="number"], input[type="password"], input[type="email"], textarea, select { 
    width: 100%; 
    padding: 10px 12px; 
    background: var(--bg-main); /* Замінили напівпрозорий чорний на змінну фону */
    border: 1px solid var(--border); 
    color: var(--text-main); 
    border-radius: var(--radius-sm); 
    box-sizing: border-box; 
    font-family: inherit; 
    transition: var(--transition); 
}

/* Робимо підказки всередині полів читабельними для всіх тем */
input::placeholder, textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
}

input[type="color"] { width: 100%; height: 40px; padding: 2px; background: var(--bg-main); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; }

input:focus, textarea:focus, select:focus { 
    outline: none; 
    border-color: var(--accent); 
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent); 
    background: var(--bg-main); 
}
input[type="color"] { width: 100%; height: 40px; padding: 2px; background: var(--bg-main); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; }
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 20%, transparent); background: color-mix(in srgb, var(--bg-color) 70%, transparent);}

.slider-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 12px; width: 100%; box-sizing: border-box; }
.slider-row label { margin: 0; flex: 0 0 110px; font-size: 0.85rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500; text-transform: none;}
.slider-row input[type="range"] { flex: 1; min-width: 0; width: 100%; accent-color: var(--accent); cursor: pointer; margin: 0; padding: 0; }
.slider-val { font-weight: bold; color: var(--accent); flex: 0 0 25px; text-align: right; font-size: 0.9rem; }

.error-item { display: flex; align-items: center; justify-content: space-between; gap: 10px; background: color-mix(in srgb, var(--bg-color) 80%, transparent); border: 1px solid var(--border); padding: 8px 12px; border-radius: var(--radius-sm); margin-bottom: 8px; transition: var(--transition); width: 100%; box-sizing: border-box;}
.error-item:hover { border-color: var(--text-muted); }
.error-label { display: flex; align-items: flex-start; gap: 10px; cursor: pointer; flex-grow: 1; color: var(--text-main); font-size: 0.9rem; margin: 0; overflow: hidden; text-overflow: ellipsis;}
.error-label input { width: auto; margin-top: 3px; cursor: pointer; flex-shrink: 0;}
.icon-btn { background: transparent; border: none; color: var(--text-muted); cursor: pointer; font-size: 1rem; padding: 4px; transition: var(--transition); border-radius: 4px; flex-shrink: 0;}
.icon-btn:hover { background: var(--bg-hover); color: var(--text-main); }
.icon-btn.delete:hover { color: var(--loss); background: rgba(239, 68, 68, 0.1); }

/* === КНОПКИ === */
.btn-primary { 
    width: 100%; padding: 12px 16px; 
    background: linear-gradient(135deg, var(--accent), var(--accent-hover)); color: white; 
    border: none; border-radius: var(--radius-md); 
    font-weight: 600; font-size: 0.95rem; font-family: inherit; 
    cursor: pointer; transition: var(--transition); 
    margin-top: 10px; flex-shrink: 0; box-sizing: border-box;
    box-shadow: 0 4px 14px color-mix(in srgb, var(--accent) 35%, transparent);
}
.btn-primary:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 45%, transparent); }
.btn-primary:active { transform: translateY(0); }

.btn-secondary { 
    padding: 10px 20px; 
    background: transparent; color: var(--text-muted); 
    border: 1px solid var(--border); border-radius: var(--radius-sm); 
    cursor: pointer; font-size: 0.85rem; font-family: inherit; 
    transition: var(--transition); font-weight: 600; box-sizing: border-box;
}
.btn-secondary:hover { color: var(--text-main); background: var(--bg-hover); border-color: var(--text-muted);}

.btn-ai { background: var(--ai-bg); border: 1px solid var(--ai-border); color: #c7d2fe; transition: var(--transition); width: 100%; padding: 10px; border-radius: var(--radius-sm); font-weight: 700; font-family: inherit; cursor: pointer; margin-top: 10px; box-sizing: border-box;}
.btn-ai:hover { background: #312e81; color: white; border-color: #312e81;}

.data-actions { display: flex; gap: 10px; margin-top: 15px; flex-shrink: 0; width: 100%; box-sizing: border-box;}
#file-input { display: none; }

/* === ГОЛОВНА ОБЛАСТЬ === */
.main-content { flex-grow: 1; display: flex; flex-direction: column; overflow-y: hidden; padding-right: 5px;}

/* Верхні вкладки (Main Tabs) + Mobile Tabs Wrapper */
.mobile-tabs-wrapper { display: flex; align-items: center; gap: 12px; width: 100%; margin-bottom: var(--spacing-lg); position: relative; flex-shrink: 0; z-index: 200; overflow: visible; }
#main-tabs-container { flex: 1; min-width: 0; overflow: visible; padding: 4px; scrollbar-width: none; }
#main-tabs-container::-webkit-scrollbar { display: none; }
.main-tabs {
    display: flex; gap: 6px; padding: 4px;
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border-radius: var(--radius-md);
    border: var(--glass-border);
    box-shadow: var(--glass-shadow);
    flex-shrink: 0; min-width: max-content; overflow: visible;
}
.main-tab-btn { flex: 1; min-width: 100px; padding: 12px 18px; background: transparent; border: none; color: var(--text-muted); border-radius: var(--radius-sm); font-family: inherit; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: var(--transition); white-space: nowrap; }
.main-tab-btn:hover:not(.active) { color: var(--text-primary); background: color-mix(in srgb, var(--text-primary) 5%, transparent); }
.main-tab-btn.active { background: var(--accent); color: var(--tab-active-text, white); box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 40%, transparent); }
.team-toggle-btn {
    padding: 10px 18px; border-radius: var(--radius-md);
    border: var(--glass-border);
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--text-main); cursor: pointer; font-weight: 600; font-size: 0.85rem;
    transition: var(--transition); white-space: nowrap;
    box-shadow: var(--glass-shadow); font-family: inherit;
}
.team-toggle-btn:hover { background: var(--bg-hover); border-color: var(--accent); color: var(--accent); }
.sidebar-toggle-btn {
    margin-left: auto; padding: 10px 18px; border-radius: var(--radius-md);
    border: var(--glass-border);
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--text-main); cursor: pointer; font-weight: 600; font-size: 0.85rem;
    transition: var(--transition); white-space: nowrap;
    box-shadow: var(--glass-shadow); font-family: inherit;
}
.sidebar-toggle-btn:hover { background: var(--bg-hover); border-color: var(--accent); color: var(--accent); }
.sidebar-btn-mobile { display: none; }
@media (max-width: 1024px) {
    .sidebar-btn-desktop { display: none; }
    .sidebar-btn-mobile { display: inline; }
}

.view-content { display: none; flex-direction: column; gap: 20px; overflow-y: auto; flex: 1; min-height: 0; padding-bottom: 30px; }
.view-content.active { display: flex; animation: fadeInSlide 0.25s ease-out; }

/* Панелі (Cards) */
.panel {
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    border: var(--glass-border);
    box-shadow: var(--glass-shadow);
    flex-shrink: 0;
}

.news-tabs { display: flex; flex-wrap: wrap; background: var(--bg-main); padding: 4px; border-radius: var(--radius-sm); gap: 4px;}
.news-tab-btn { padding: 6px 12px; text-align: center; background: transparent; color: var(--text-muted); border: none; border-radius: 6px; cursor: pointer; font-weight: 600; transition: var(--transition); font-size: 0.85rem; font-family: inherit;}
.news-tab-btn.active { background: var(--bg-panel); color: var(--text-main); box-shadow: var(--shadow-sm); }

.param-setup-row { display: flex; gap: 10px; margin-bottom: 10px; align-items: center; }
.param-setup-row input.param-name { flex: 1; font-weight: 600;}
.param-setup-row button { width: auto; margin: 0; padding: 10px; }

/* === КАЛЕНДАР І АВТО-РЕКОРДИ === */
.grid { display: grid; grid-template-columns: 45px repeat(5, minmax(0, 1fr)); gap: 12px; }
.grid.stretch-rows { grid-template-rows: auto; grid-auto-rows: 1fr; }
.day-header { text-align: right; font-weight: 600; color: var(--text-muted); padding-bottom: 8px; font-size: 0.9rem; }

/* FIX 2: week-label keeps a simple semi-transparent bg — no backdrop-filter */
.week-label {
    display: flex; align-items: center; justify-content: center;
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    cursor: pointer; font-size: 1.2rem;
    transition: var(--transition);
    color: var(--text-secondary);
    min-height: 75px;
}
[data-theme="light"] .week-label { background: rgba(255, 255, 255, 0.35); }
.week-label.has-comment { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); }

/* FIX 2: day-cell — lightweight flat bg, no backdrop-filter, no color-mix */
.day-cell {
    background: rgba(0, 0, 0, 0.15);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    min-height: 75px; padding: 12px;
    display: flex; flex-direction: column; justify-content: space-between;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
    position: relative;
}
[data-theme="light"] .day-cell { background: rgba(255, 255, 255, 0.35); }
.day-cell:hover:not(.empty) { 
    background-color: var(--bg-panel) !important;
    border-color: var(--accent); 
    z-index: 10; 
    box-shadow: var(--shadow-md); 
}
.day-cell.active-day { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in srgb, var(--accent) 35%, transparent); background: color-mix(in srgb, var(--accent) 5%, transparent); }
.day-cell.empty { background: transparent; border: none; cursor: default; }
.day-number { font-size: 0.85rem; font-weight: 700; color: var(--text-muted); }
.day-pnl { font-size: 1.1rem; font-weight: 700; text-align: right; margin-top: auto; }

.green { border-color: rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.08); color: var(--profit); }
.red { border-color: rgba(239, 68, 68, 0.2); background: rgba(239, 68, 68, 0.08); color: var(--loss); }

/* Логіка рекордів */
.record-day { border: 2px solid var(--gold) !important; box-shadow: 0 0 15px rgba(234, 179, 8, 0.5); background: rgba(234, 179, 8, 0.15) !important; }
.record-day-old { border: 1px solid var(--gold) !important; background: rgba(234, 179, 8, 0.05) !important; opacity: 0.85; }
.dayloss-day { border: 2px solid var(--loss) !important; box-shadow: 0 0 12px rgba(239, 68, 68, 0.4); background: rgba(239, 68, 68, 0.15) !important; }
.error-day { }

.text-green { color: var(--profit); }
.text-red { color: var(--loss); }

#tooltip {
    position: fixed; display: none;
    background: color-mix(in srgb, var(--panel-color) 85%, transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--text-main); padding: 12px 16px; border-radius: var(--radius-sm);
    font-size: 0.9rem; line-height: 1.5; pointer-events: none; z-index: 1000;
    max-width: 320px; box-shadow: var(--glass-shadow);
    border: var(--glass-border); white-space: pre-wrap; font-family: var(--font-main);
}

#image-preview { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); backdrop-filter: blur(4px); z-index: 99999; display: none; align-items: center; justify-content: center; cursor: zoom-out; }
#image-preview img { max-height: 90vh; max-width: 90vw; display: block; border-radius: var(--radius-sm); object-fit: contain; cursor: pointer; border: 2px solid var(--accent); box-shadow: 0 20px 60px rgba(0,0,0,0.9); transition: transform 0.2s;}
#image-preview img:hover { transform: scale(1.02); }

.chart-container { height: 200px; width: 100%; }
.folder-setup { display: flex; gap: 10px; align-items: flex-end; }

/* === СКРІНШОТИ === */
.unassigned-gallery { display: flex; gap: 15px; overflow-x: auto; padding-bottom: 25px; padding-top: 15px; align-items: stretch;}
.unassigned-item { min-width: 300px; max-width: 300px; background: color-mix(in srgb, var(--bg-color) 80%, transparent); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 10px; display: flex; flex-direction: column; gap: 10px; position: relative; transition: var(--transition);}

.img-zoom-wrapper { position: relative; width: 100%; }
.img-zoom-wrapper img { width: 100%; height: auto; border-radius: 6px; cursor: pointer; border: 1px solid var(--border); transition: var(--transition); display: block; }
.img-zoom-wrapper img:hover { opacity: 0.7; border-color: var(--accent); }

.ticker-badge { position: absolute; top: 5px; left: 5px; background: color-mix(in srgb, var(--bg-color) 20%, transparent); color: var(--gold); padding: 4px 8px; border-radius: 4px; font-weight: bold; font-size: 0.9rem; z-index: 5; border: 1px solid var(--gold); box-shadow: var(--shadow-sm); transition: var(--transition); display: flex; gap: 8px;}
.ticker-badge span { cursor: pointer; opacity: 0.8; transition: var(--transition);}
.ticker-badge span:hover { opacity: 1; text-shadow: 0 0 5px white;}

.assign-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.assign-btn { background: var(--bg-hover); color: white; border: none; padding: 8px; border-radius: var(--radius-sm); cursor: pointer; font-size: 0.85rem; font-weight: 600; font-family: inherit; transition: var(--transition);}
.assign-btn.good:hover { background: var(--profit); }
.assign-btn.normal:hover { background: #eab308; color: black;}
.assign-btn.bad:hover { background: #f97316; }
.assign-btn.error:hover { background: var(--loss); }
.assign-btn.delete { grid-column: span 2; background: rgba(239, 68, 68, 0.1); color: var(--loss); border: 1px solid rgba(239,68,68,0.3); margin-top: 5px;}
.assign-btn.delete:hover { background: var(--loss); color: white; }

.big-screen-cat { margin-top: 20px; border: 1px solid var(--border); border-radius: var(--radius-lg); background: var(--bg-main); padding: 20px; }
.big-screen-cat h4 { margin-top: 0; font-size: 1.3rem; margin-bottom: 15px; border-bottom: 1px solid var(--border); padding-bottom: 10px;}
.screen-tags-wrap { margin-top: 10px; }
.screen-tags-list { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
.screen-tag { background: var(--accent); color: white; padding: 3px 8px; border-radius: 12px; font-size: 0.78rem; cursor: pointer; transition: 0.2s; }
.screen-tag:hover { background: var(--loss); }
.screen-tag-input { background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: 6px; padding: 4px 8px; font-size: 0.85rem; width: 120px; }
.tag-suggestions {
    position: absolute; top: 100%; left: 0;
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: var(--glass-border);
    border-radius: 8px; z-index: 100; min-width: 150px;
    box-shadow: var(--glass-shadow); display: none;
}
.tag-suggestion-item { padding: 7px 12px; cursor: pointer; font-size: 0.85rem; transition: 0.15s; }
.tag-suggestion-item:hover { background: var(--bg-hover); color: var(--accent); }
.big-screen-item { position: relative; margin-bottom: 30px; background: var(--bg-panel); padding: 15px; border-radius: var(--radius-md); border: 1px solid var(--border); box-shadow: var(--shadow-sm); }
.big-screen-item img { width: 100%; height: auto; border-radius: var(--radius-sm); cursor: pointer; border: 1px solid var(--border); transition: var(--transition);}
.big-screen-item img:hover { opacity: 0.8; border-color: var(--accent); }

#ocr-setup-container { position: relative; width: 100%; height: 400px; overflow: hidden; border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: crosshair; background: var(--bg-color); }
#ocr-zoom-wrapper { position: absolute; transform-origin: 0 0; display: inline-block; }
#ocr-setup-img { display: block; user-select: none; -webkit-user-drag: none; pointer-events: none; }
#ocr-selection-box { position: absolute; border: 2px dashed var(--gold); background: rgba(234, 179, 8, 0.2); display: none; pointer-events: none; z-index: 10;}

/* СТАТИСТИКА ТА ДЕРЕВО НАВІГАЦІЇ */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 15px; margin-bottom: 25px; }
.stat-card {
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: var(--glass-border);
    padding: 18px;
    border-radius: var(--radius-lg);
    text-align: center;
    box-shadow: var(--glass-shadow);
    transition: box-shadow 0.2s ease;
}
.stat-card .value { font-size: 1.7rem; font-weight: 800; margin-top: 6px; color: var(--text-main); letter-spacing: -0.02em; }
.stat-card .label { font-size: 0.78rem; color: var(--text-muted); font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
.stat-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.3), var(--glass-shadow); }

/* === ГОРИЗОНТАЛЬНА ПАНЕЛЬ ФІЛЬТРІВ СТАТИСТИКИ === */
.stats-filters-bar {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-items: center;
}

.stats-bar-item {
    position: relative;
}

.stats-bar-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: var(--radius-md);
    border: var(--glass-border);
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    color: var(--text-main);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
    font: inherit;
    white-space: nowrap;
    box-shadow: var(--glass-shadow);
}
.stats-bar-trigger:hover { border-color: var(--accent); background: var(--bg-hover); }
.stats-bar-trigger.open { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, var(--bg-panel)); }
.stats-bar-trigger.open .stats-dropdown-caret { transform: rotate(180deg); }

.stats-bar-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
}
.stats-bar-value {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-main);
}

.stats-bar-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 220px;
    z-index: 50;
    padding: 14px;
    border-radius: var(--radius-lg);
    border: var(--glass-border);
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    display: none;
    overflow: hidden; /* FIX 1: clip children to rounded corners */
}
.stats-bar-dropdown.open {
    display: block;
}

.stats-dropdown-caret { transition: transform 0.2s ease; color: var(--accent); font-size: 0.75rem; }

/* Старі стилі (залишаємо для сумісності) */
.stats-filters-panel,
.stats-sidebar-panel { background: var(--bg-panel); border: 1px solid var(--border); box-shadow: var(--shadow-md); min-width: 0; }
.stats-source-panel { border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--bg-panel); box-shadow: var(--shadow-md); }
.stats-sidebar-wrap { min-width: 0; }
.stats-dropdown-wrap { position: relative; }
.stats-dropdown-label { margin-bottom: 8px; color: var(--text-muted); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
.stats-dropdown-trigger { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 14px 16px; border-radius: 14px; border: 1px solid var(--border); background: var(--bg-panel); color: var(--text-main); cursor: pointer; transition: border-color 0.2s ease; box-shadow: var(--shadow-sm); text-align: left; font: inherit; }
.stats-dropdown-trigger:hover { border-color: var(--accent); }
.stats-dropdown-trigger.open .stats-dropdown-caret { transform: rotate(180deg); }
.stats-dropdown-panel { position: absolute; top: calc(100% + 10px); left: 0; right: 0; z-index: 20; padding: 14px; border-radius: var(--radius-lg); border: 1px solid var(--border); background: var(--bg-panel); box-shadow: var(--shadow-lg); }
.stats-source-panel h3 { margin-top: 0; }

.tree-nav { list-style: none; padding: 0; margin: 0; }
.tree-nav ul { list-style: none; padding-left: 15px; margin: 0; }
.tree-item { display: flex; align-items: center; padding: 7px 9px; margin-bottom: 3px; border-radius: var(--radius-md); cursor: pointer; transition: 0.2s; color: var(--text-muted); font-size: 0.95rem; border: 1px solid transparent; }
.tree-item:hover { background: color-mix(in srgb, var(--text-secondary) 8%, transparent); color: var(--text-primary); transform: translateX(2px); }
.tree-item.active-filter { background: color-mix(in srgb, var(--accent) 15%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent); font-weight: 600; box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 12%, transparent) inset; }
.tree-toggle { width: 20px; display: inline-block; text-align: center; font-size: 0.8rem; }
.tree-label { flex-grow: 1; }

.stats-group-title { color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; margin: 12px 0 6px 0; font-weight: 700; letter-spacing: 0.05em; }
.stats-source-btn { width: 100%; padding: 10px 14px; text-align: left; background: var(--bg-main); border: 1px solid var(--border); color: var(--text-main); border-radius: var(--radius-sm); cursor: pointer; font-size: 0.9rem; transition: var(--transition); margin-bottom: 6px; font-family: inherit; }
.stats-source-btn:hover { background: var(--bg-hover); border-color: var(--accent); }
.stats-source-btn.active { background: color-mix(in srgb, var(--accent) 20%, transparent); border-color: var(--accent); color: var(--accent); font-weight: 600; }

/* === ПАНЕЛЬ КОМАНДИ === */
.team-sidebar-panel { font-family: var(--font-main); }
.team-sidebar-header { display: flex; justify-content: space-between; align-items: center; padding: 20px 20px 16px; border-bottom: 1px solid var(--border); background: color-mix(in srgb, var(--bg-color) 85%, transparent); }
.team-sidebar-title { color: var(--text-main); margin: 0; font-size: 1.25rem; font-weight: 700; }
.team-sidebar-close { background: transparent; border: none; color: var(--text-muted); font-size: 1.25rem; cursor: pointer; padding: 4px 8px; border-radius: var(--radius-sm); transition: var(--transition); line-height: 1; }
.team-sidebar-close:hover { color: var(--text-main); background: var(--bg-hover); }
.team-list-container { padding: 16px; }
.team-my-profile { margin-bottom: 20px; }
.team-member-btn { width: 100%; padding: 12px 16px; border-radius: var(--radius-md); border: 1px solid var(--border); background: var(--bg-main); color: var(--text-main); cursor: pointer; font-weight: 600; font-size: 0.95rem; transition: var(--transition); display: flex; align-items: center; gap: 10px; font-family: inherit; text-align: left; }
.team-member-btn:hover { background: var(--bg-hover); border-color: var(--accent); }
.team-member-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
.team-group-title { color: var(--accent); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin: 20px 0 10px 0; padding: 0 4px; }
.team-member-item { padding: 12px 16px; margin: 6px 0; border-radius: var(--radius-md); cursor: pointer; transition: var(--transition); display: flex; align-items: center; gap: 12px; border: 1px solid transparent; background: var(--bg-main); }
.team-member-item:hover { background: var(--bg-hover); border-color: var(--border); }
.team-member-item.active { background: color-mix(in srgb, var(--accent) 15%, transparent); border-color: var(--accent); border-left: 3px solid var(--accent); }
.team-member-icon { font-size: 1.2rem; flex-shrink: 0; }
.team-member-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.team-sidebar-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 100001; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
.team-sidebar-backdrop.visible { opacity: 1; pointer-events: auto; }

/* === СУЧАСНІ НАЛАШТУВАННЯ ТЕМИ === */
.theme-settings-panel .panel-title { color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 12px; margin-bottom: 20px; font-size: 1.1rem; }
.theme-section { margin-bottom: 24px; }
.theme-section-label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
.theme-cards { display: flex; flex-wrap: wrap; gap: 12px; }
.theme-card {
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    padding: 12px;
    border-radius: var(--radius-md);
    border: 2px solid var(--border);
    cursor: pointer;
    transition: var(--transition);
    min-width: 72px;
    position: relative;
    overflow: hidden; /* FIX 1: clip preview swatch to rounded corners */
}
.theme-card:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 5%, transparent); }
.theme-card input { position: absolute; opacity: 0; }
.theme-card input:checked + .theme-card-preview { box-shadow: 0 0 0 2px var(--accent); }
.theme-card:has(input:checked) { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); }
.theme-card-preview { width: 48px; height: 32px; border-radius: 6px; display: block; }
.theme-preview-dark { background: linear-gradient(135deg, #0f172a 50%, #1e293b 50%); }
.theme-preview-light { background: linear-gradient(135deg, #f1f5f9 50%, #ffffff 50%); }
.theme-preview-matrix { background: #000; box-shadow: inset 0 0 0 1px #00ff00; }
.theme-preview-dracula { background: linear-gradient(135deg, #282a36 50%, #44475a 50%); }
.theme-preview-custom { background: linear-gradient(135deg, #6366f1, #8b5cf6); font-size: 1.2rem; display: flex; align-items: center; justify-content: center; }
.theme-card-name { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); }

/* === ОНОВЛЕНИЙ БЛОК СВОЄЇ ТЕМИ === */
.custom-theme-block { display: none; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border); }
.custom-theme-block[data-visible="true"] { display: block; animation: fadeInSlide 0.3s ease-out; }
.custom-theme-hint { color: var(--text-muted); font-size: 0.85rem; margin-bottom: 16px; font-weight: 500; }

.theme-color-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

.theme-color-item { 
    background: color-mix(in srgb, var(--bg-color) 85%, transparent); 
    padding: 12px; 
    border-radius: var(--radius-md); 
    border: 1px solid var(--border); 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    transition: var(--transition); 
}
.theme-color-item:hover { 
    border-color: var(--accent); 
    background: color-mix(in srgb, var(--accent) 5%, transparent); 
    transform: translateY(-2px); 
    box-shadow: var(--shadow-sm); 
}
.theme-color-item label { 
    display: block; 
    font-size: 0.75rem; 
    color: var(--text-primary); 
    margin-bottom: 8px; 
    font-weight: 700; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
}

/* Ховаємо стандартні браузерні рамки кольору */
.color-input-wrapper { 
    width: 100%; 
    height: 36px; 
    border-radius: 8px; 
    overflow: hidden; 
    border: 2px solid transparent; 
    transition: var(--transition); 
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1); 
    position: relative;
}
.theme-color-item:hover .color-input-wrapper { 
    border-color: rgba(255,255,255,0.2); 
}
.theme-color-item input[type="color"] { 
    width: 150%; 
    height: 150%; 
    margin: -25%; 
    padding: 0; 
    border: none; 
    cursor: pointer; 
    background: transparent; 
    outline: none; 
}
.theme-color-item input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
.theme-color-item input[type="color"]::-webkit-color-swatch { border: none; }
.theme-color-item input[type="color"]::-moz-color-swatch { border: none; }

.font-pills { display: flex; flex-wrap: wrap; gap: 8px; }
.font-pill { padding: 8px 16px; border-radius: 999px; border: 1px solid var(--border); cursor: pointer; font-size: 0.9rem; transition: var(--transition); }
.font-pill:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); }
.font-pill input { display: none; }
.font-pill:has(input:checked) { background: var(--accent); border-color: var(--accent); color: white; }
.btn-save-theme { width: auto; margin-top: 8px; }

@keyframes fadeInSlide { from { opacity: 0; } to { opacity: 1; } }

/* === AI ЧАТ (TELEGRAM STYLE + ФЛАЖОК) === */
.ai-response-box { display: none; } /* Видалили старе спливаюче вікно */

#data-chat-box { padding: var(--spacing-md); background: color-mix(in srgb, var(--bg-color) 90%, transparent); border-radius: var(--radius-md); }
.chat-history { padding: 20px; flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; margin-bottom: 15px;}
.chat-msg { max-width: 80%; padding: 10px 16px; border-radius: 16px; font-size: 0.95rem; line-height: 1.4; position: relative; word-wrap: break-word;}
.user-msg { align-self: flex-end; background: var(--accent); color: white; border-bottom-right-radius: 4px; }
.ai-msg { align-self: flex-start; background: var(--bg-color); color: var(--text-primary); border: 1px solid var(--border); border-bottom-left-radius: 4px; }
.btn-save-icon { opacity: 0.4; font-size: 1.2rem; margin-left: 8px; color: var(--text-muted); background: transparent; border: none; cursor: pointer; transition: var(--transition);}
.btn-save-icon:hover { opacity: 1; color: var(--accent); transform: scale(1.1); }

/* --- КНОПКА ТА ЧАТ SOS --- */
#sos-btn {
    position: fixed; bottom: 30px; right: 30px;
    background: #ef4444; color: white; border: none; border-radius: 50px;
    padding: 15px 25px; font-size: 1.2rem; font-weight: 800;
    cursor: pointer; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);
    z-index: 1000; transition: background-color 0.2s ease; font-family: inherit;
    display: flex; align-items: center; justify-content: center;
    will-change: transform;
}
#sos-btn:hover { background: #dc2626; }

@keyframes pulse-red {
    0%, 100% { box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4); }
    50% { box-shadow: 0 4px 25px rgba(239, 68, 68, 0.7); }
}
@keyframes sos-blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }

.modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: color-mix(in srgb, var(--bg-color) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 9999; display: none; align-items: center; justify-content: center;
}
.modal-content.sos-theme {
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    width: 95%; max-width: 600px;
    border-radius: var(--radius-lg);
    border: var(--glass-border);
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 0 0 40px rgba(239, 68, 68, 0.25), var(--glass-shadow);
}
.modal-header { padding: 15px 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: color-mix(in srgb, var(--loss) 10%, transparent); }
.close-btn { background: none; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; transition: 0.2s;}
.close-btn:hover { color: #ef4444; }

.chat-input-area { padding: 15px; border-top: 1px solid var(--border); display: flex; gap: 10px; background: var(--bg-main); }

/* === АВТОРИЗАЦІЯ === */
.auth-card { 
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent) !important;
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    padding: 40px !important; 
    border-radius: var(--radius-xl) !important; 
    border: var(--glass-border) !important; 
    width: 380px !important; 
    text-align: center;
    box-shadow: var(--glass-shadow);
}
#auth-overlay { background: var(--bg-main) !important; }

/* === МОБІЛЬНА ВЕРСІЯ (АДАПТИВНІСТЬ) === */
.mobile-only { display: none; }
.form-sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 100001; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
.form-sidebar-backdrop.visible { display: block; opacity: 1; pointer-events: auto; }

/* === BOTTOM NAVIGATION BAR (тільки мобільна) === */
.mobile-bottom-nav { display: none; }

@media (max-width: 1024px) {
    body { padding: 0; gap: 0; height: auto; min-height: 100dvh; overflow-x: hidden; overflow-y: auto; flex-direction: column; -webkit-overflow-scrolling: touch; }

    .sidebar {
        position: fixed; top: 0; left: 0; width: min(92vw, 420px); min-width: 0; height: 100dvh; max-height: 100dvh;
        border-radius: 0 18px 18px 0; z-index: 100002; transform: translateX(-105%); padding: 18px; box-shadow: 18px 0 40px rgba(0, 0, 0, 0.45);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); overflow-y: auto;
        -webkit-overflow-scrolling: touch; padding-bottom: env(safe-area-inset-bottom);
    }
    .sidebar.open { transform: translateX(0); }

    #mobile-close-sidebar, #mobile-menu-btn, .mobile-only { display: flex !important; }
    .form-sidebar-backdrop.visible { display: block !important; }

    /* Верхній хедер */
    .mobile-tabs-wrapper {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        padding: max(10px, env(safe-area-inset-top)) 12px 10px;
        background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
        -webkit-backdrop-filter: var(--glass-blur);
        backdrop-filter: var(--glass-blur);
        border-bottom: var(--glass-border);
        display: flex !important;
        align-items: center;
        gap: 10px;
        flex-wrap: nowrap;
        min-height: 54px;
    }
    #main-tabs-container { display: none !important; }
    .tab-nav-btn { display: none !important; }
    #sidebar-toggle-btn { display: none !important; }

    #mobile-section-title {
        display: block !important;
        flex: 1;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mobile-menu-btn {
        display: flex !important;
        align-items: center; justify-content: center;
        padding: 8px 12px; min-height: 44px; min-width: 44px;
        border: 1px solid var(--border); border-radius: var(--radius-md);
        background: var(--bg-main); color: var(--text-main);
        font-weight: 600; cursor: pointer; font-size: 1rem;
        font-family: inherit;
        flex-shrink: 0;
    }
    .team-toggle-btn {
        min-height: 44px; padding: 8px 12px; flex-shrink: 0;
        touch-action: manipulation; font-size: 0.85rem;
    }

    /* Bottom Navigation Bar */
    .mobile-bottom-nav {
        display: flex;
        position: fixed;
        bottom: 0; left: 0; right: 0;
        z-index: 200;
        background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
        -webkit-backdrop-filter: var(--glass-blur);
        backdrop-filter: var(--glass-blur);
        border-top: var(--glass-border);
        padding-bottom: env(safe-area-inset-bottom);
        box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
        overflow-x: auto;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
    }
    .mobile-bottom-nav::-webkit-scrollbar { display: none; }
    .mobile-nav-btn {
        flex: 0 0 auto;
        min-width: 64px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        padding: 10px 8px;
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        font-family: inherit;
        font-size: 0.62rem;
        font-weight: 600;
        transition: color 0.2s ease;
        touch-action: manipulation;
        min-height: 56px;
        -webkit-tap-highlight-color: transparent;
        white-space: nowrap;
    }
    .mobile-nav-btn .nav-icon { font-size: 1.3rem; line-height: 1; }
    .mobile-nav-btn.active { color: var(--accent); }
    .mobile-nav-btn.active .nav-icon { filter: drop-shadow(0 0 4px color-mix(in srgb, var(--accent) 60%, transparent)); }
    .mobile-nav-more-btn.more-open { color: var(--accent); }

    .mobile-more-item {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 4px; padding: 10px 4px;
        background: var(--bg-main); border: 1px solid var(--border); border-radius: var(--radius-md);
        color: var(--text-muted); font-family: inherit; font-size: 0.7rem; font-weight: 600;
        cursor: pointer; transition: var(--transition);
        -webkit-tap-highlight-color: transparent;
    }
    .mobile-more-item span:first-child { font-size: 1.3rem; line-height: 1; }
    .mobile-more-item:active, .mobile-more-item.active { background: color-mix(in srgb, var(--accent) 15%, transparent); border-color: var(--accent); color: var(--accent); }

    #mobile-more-menu {
        bottom: calc(56px + env(safe-area-inset-bottom)) !important;
    }

    /* Контент */
    .main-content {
        width: 100%; min-width: 0; overflow: visible;
        padding: 0 12px;
        padding-top: calc(max(10px, env(safe-area-inset-top)) + 54px);
        padding-bottom: calc(56px + env(safe-area-inset-bottom) + 16px);
    }
    .view-content { padding-bottom: 8px; }

    /* Дашборд тулбар — компактний на мобільному */
    .dash-toolbar {
        flex-direction: column !important;
        gap: 10px !important;
    }
    .dash-toolbar-controls {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: wrap;
        gap: 8px !important;
        align-items: center;
    }
    .dash-toolbar-totals {
        display: flex !important;
        flex-direction: row !important;
        flex-wrap: wrap;
        gap: 8px !important;
        align-items: center;
        font-size: 0.85rem;
    }
    #winstreak-counter { margin-left: 0 !important; font-size: 0.95rem !important; }

    /* Статистика — вертикально */
    .stats-layout { flex-direction: column !important; gap: 14px !important; overflow: visible !important; height: auto !important; }
    .stats-main-panel { overflow: visible !important; }
    .stats-charts-row { flex-direction: column !important; gap: 14px !important; }
    .stats-chart-panel-wide, .stats-chart-panel { min-width: 0 !important; flex: 1 1 auto !important; }
    .stats-bar-dropdown { position: static; margin-top: 8px; min-width: 0; }
    .stats-filters-bar { gap: 6px; }

    /* AI вкладка — висота авто */
    #view-ai > div { height: auto !important; min-height: 0; }
    #ai-chat-section { min-height: 60dvh; }
    #data-chat-box { min-height: 200px; max-height: 45dvh; overflow-y: auto; }

    .panel { padding: 14px; border-radius: 14px; }
    .sidebar-form-row, .folder-setup, .chat-input-area, .data-actions, .param-setup-row { flex-direction: column; align-items: stretch !important; }
    .mobile-data-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .mobile-action-btn { width: 100%; min-width: 0; margin: 0; }
    .mobile-action-btn-small { padding: 9px 8px; font-size: 0.78rem; }
    .mobile-action-btn-import { padding: 9px 8px; font-size: 0.8rem; }

    .stats-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
    .theme-color-grid { grid-template-columns: 1fr 1fr; }
    .unassigned-item { min-width: min(78vw, 300px); max-width: min(78vw, 300px); }

    #sos-btn { bottom: calc(56px + env(safe-area-inset-bottom) + 12px); right: max(16px, env(safe-area-inset-right)); min-width: 48px; min-height: 48px; touch-action: manipulation; display: none !important; }

    .modal-content.sos-theme { width: calc(100vw - 20px); max-width: none; max-height: 88dvh; }
    .chat-history { height: auto; min-height: 240px; max-height: 45dvh; padding: 16px; }
    .chat-input-area { flex-direction: row !important; }
    .chat-input-area input { flex: 1; width: auto !important; }
    .chat-input-area button { width: auto !important; }
}

@media (max-width: 768px) {
    body { padding: 0; }
    .main-content { padding-left: 10px; padding-right: 10px; }
    .auth-card { width: min(92vw, 350px) !important; padding: 24px !important; }
    .date-display { font-size: 1rem; }
    .tabs { margin-bottom: 14px; }
    .tab-btn { font-size: 0.82rem; padding: 10px 6px; }
    .mobile-action-btn-small, .mobile-action-btn-import { font-size: 0.74rem; padding: 8px 6px; }
    .stats-grid { grid-template-columns: 1fr 1fr; }
    .stat-card .value { font-size: 1.35rem; }
    .theme-color-grid { grid-template-columns: 1fr; }
    .grid { gap: 6px; }
    .day-cell, .week-label { min-height: 58px; padding: 7px; }
    .day-number { font-size: 0.82rem; }
    .day-pnl { font-size: 0.88rem; }
    .slider-row { display: grid; grid-template-columns: 1fr auto; grid-template-areas: "label value" "slider slider"; gap: 8px; align-items: center; }
    .slider-row label { grid-area: label; flex: none; white-space: normal; }
    .slider-row input[type="range"] { grid-area: slider; }
    .slider-val { grid-area: value; }
    .assign-btns { grid-template-columns: 1fr; }
    .assign-btn.delete { grid-column: span 1; }
    .news-tabs { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 2px; scrollbar-width: none; }
    .news-tabs::-webkit-scrollbar { display: none; }
    .news-tab-btn { flex: 0 0 auto; white-space: nowrap; }
    #ocr-setup-container { height: 280px; }
    #team-sidebar { width: min(92vw, 320px); left: calc(-1 * min(92vw, 320px) - 24px); }
    #team-sidebar.open { left: 0; }
    .team-sidebar-backdrop.visible { display: block !important; }
    .theme-cards { gap: 8px; }
    .theme-card { min-width: 60px; padding: 10px; }
    .theme-card-preview { width: 40px; height: 26px; }
    .font-pills { gap: 6px; }
    .font-pill { padding: 6px 12px; font-size: 0.85rem; }
    .team-manager-card { width: calc(100vw - 20px) !important; padding: 18px !important; }
}

.learn-card { display:flex; flex-direction:column; background:var(--bg-main); border:1px solid var(--border); border-radius:var(--radius-md); overflow:hidden; text-decoration:none; color:var(--text-main); transition:var(--transition); }
.learn-card:hover { border-color:var(--accent); transform:translateY(-3px); box-shadow:var(--shadow-md); }
.learn-card-body { padding:12px; }
.learn-card-title { font-size:0.9rem; font-weight:600; margin-bottom:6px; line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.learn-card-meta { font-size:0.78rem; color:var(--text-muted); }

.more-tabs-wrap { position: relative; z-index: 201; }
.more-tabs-dropdown {
    flex-direction: column;
    position: absolute; top: calc(100% + 6px); right: 0;
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    border: var(--glass-border);
    border-radius: var(--radius-md);
    box-shadow: var(--glass-shadow);
    z-index: 9999; min-width: 160px; padding: 6px;
    overflow: hidden; /* FIX 1: clip children to rounded corners */
}
.more-tab-item { display:block; width:100%; padding:10px 14px; background:transparent; border:none; color:var(--text-muted); border-radius:var(--radius-sm); font-family:inherit; font-size:0.9rem; font-weight:600; cursor:pointer; text-align:left; transition:var(--transition); white-space:nowrap; }
.more-tab-item:hover { background:var(--bg-hover); color:var(--text-main); }
.more-tab-item.active { background:var(--accent); color:white; }

/* TV Fullscreen */
#tv-widget-container.tv-fullscreen {
    position: fixed !important;
    inset: 0 !important;
    z-index: 9999 !important;
    width: 100vw !important;
    height: 100vh !important;
}

/* Pill Navigation */
#trade-pill-nav::-webkit-scrollbar { display: none; }
#trade-pill-nav {
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    overflow-x: visible;
    overflow-y: visible;
    min-width: 0;
    flex-wrap: wrap;
}
.trade-pill {
    flex-shrink: 0;
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-main);
    color: var(--text-muted);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: var(--transition);
    font-family: inherit;
}
.trade-pill:hover {
    border-color: var(--accent);
    color: var(--text-main);
}
.trade-pill.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 40%, transparent);
}
.trade-pill.profit { border-color: rgba(16,185,129,0.4); }
.trade-pill.profit.active { background: #10b981; border-color: #10b981; box-shadow: 0 2px 8px rgba(16,185,129,0.4); }
.trade-pill.loss { border-color: rgba(239,68,68,0.4); }
.trade-pill.loss.active { background: #ef4444; border-color: #ef4444; box-shadow: 0 2px 8px rgba(239,68,68,0.4); }

/* ===== PLAYBOOK CHART CONSTRUCTOR ===== */
#pbc-panel { display: flex; flex-direction: column; gap: 0; }

.pbc-controls {
    display: flex;
    gap: 20px;
    align-items: flex-end;
    flex-wrap: wrap;
    margin-bottom: 14px;
}

.pbc-control-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 160px;
}

.pbc-control-group label {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
}

.pbc-control-group input[type="range"] {
    accent-color: var(--accent);
    width: 100%;
    margin: 0;
    cursor: pointer;
}

.pbc-canvas-wrap {
    position: relative;
    border: 1px dashed var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-main);
    cursor: crosshair;
}

.pbc-hint {
    position: absolute;
    top: 8px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-muted);
    font-size: 0.78rem;
    pointer-events: none;
    margin: 0;
    white-space: nowrap;
    opacity: 0.6;
}

#pbc-canvas {
    display: block;
    width: 100%;
    height: 220px;
}

.pbc-ohlc-inputs {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    flex: 1;
}

.pbc-ohlc-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 80px;
    flex: 1;
}

.pbc-ohlc-field label {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0;
}

.pbc-ohlc-field input {
    margin: 0;
    padding: 6px 8px;
    font-size: 0.9rem;
}

/* =====================================================
   GLASSMORPHISM GATE — effects only when body.glass-enabled
   Without the class every surface falls back to solid --bg-panel.
   ===================================================== */

/* --- Solid fallback (glass OFF) --- */
.sidebar,
.panel,
.stat-card,
.main-tabs,
.team-toggle-btn,
.sidebar-toggle-btn,
.stats-bar-trigger,
.stats-bar-dropdown,
.more-tabs-dropdown,
.tag-suggestions,
#tooltip,
.modal-content.sos-theme,
.auth-card,
.mobile-tabs-wrapper,
.mobile-bottom-nav {
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
    background: var(--bg-panel) !important;
    border: 1px solid var(--border) !important;
    box-shadow: var(--shadow-md) !important;
}

/* --- Frosted glass (glass ON) --- */
body.glass-enabled .sidebar,
body.glass-enabled .panel,
body.glass-enabled .stat-card,
body.glass-enabled .main-tabs,
body.glass-enabled .team-toggle-btn,
body.glass-enabled .sidebar-toggle-btn,
body.glass-enabled .stats-bar-trigger,
body.glass-enabled .stats-bar-dropdown,
body.glass-enabled .more-tabs-dropdown,
body.glass-enabled .tag-suggestions,
body.glass-enabled #tooltip,
body.glass-enabled .modal-content.sos-theme,
body.glass-enabled .auth-card,
body.glass-enabled .mobile-tabs-wrapper,
body.glass-enabled .mobile-bottom-nav {
    background: color-mix(in srgb, var(--panel-color) var(--glass-opacity), transparent) !important;
    -webkit-backdrop-filter: var(--glass-blur) !important;
    backdrop-filter: var(--glass-blur) !important;
    border: var(--glass-border) !important;
    box-shadow: var(--glass-shadow) !important;
}

/* --- Toggle switch widget --- */
.toggle-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}
.toggle-switch {
    position: relative;
    width: 44px;
    height: 24px;
    flex-shrink: 0;
}
.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
}
.toggle-track {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: var(--border);
    cursor: pointer;
    transition: background 0.2s ease;
}
.toggle-track::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s ease;
}
.toggle-switch input:checked + .toggle-track { background: var(--accent); }
.toggle-switch input:checked + .toggle-track::after { transform: translateX(20px); }
