{
  "crons": [
    {
      "path": "/api/cron/sync-google-sheets",
      "schedule": "0 20 * * *"
    }
  ],
  "rewrites": [
    { "source": "/config.js", "destination": "/api/client-config.js" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/calendar", "destination": "/index.html" },
    { "source": "/stats", "destination": "/index.html" },
    { "source": "/trades", "destination": "/index.html" },
    { "source": "/datagrid", "destination": "/index.html" },
    { "source": "/trades-table", "destination": "/index.html" },
    { "source": "/table", "destination": "/index.html" },
    { "source": "/import", "destination": "/index.html" },
    { "source": "/sheet-import", "destination": "/index.html" },
    { "source": "/screen", "destination": "/index.html" },
    { "source": "/screens", "destination": "/index.html" },
    { "source": "/ai", "destination": "/index.html" },
    { "source": "/mentor-review", "destination": "/index.html" },
    { "source": "/playbook", "destination": "/index.html" },
    { "source": "/learn", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
      ]
    }
  ]
}
